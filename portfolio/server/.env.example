# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to git — add it to .gitignore.

# The Gmail address that sends notification + auto-reply emails.
GMAIL_USER=harisinghhari2008@gmail.com

# A Gmail "App Password" — NOT your normal Google account password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the Google account first.)
# It's a 16-character code like: abcd efgh ijkl mnop  (spaces don't matter)
GMAIL_APP_PASSWORD=replace_with_your_16_char_app_password

# Where contact-form submissions are delivered. Defaults to GMAIL_USER if omitted.
OWNER_EMAIL=harisinghhari2008@gmail.com

# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend URL here once you have a domain.
# Example: ALLOWED_ORIGIN=http://localhost:5173,https://your-deployed-site.com
ALLOWED_ORIGIN=http://localhost:5173

# Port the server listens on (most serverless hosts override this automatically).
PORT=4000

# Brand name used in the email subject/body copy.
BRAND_NAME=SmartFlow
