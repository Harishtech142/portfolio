# Copy this file to .env and fill in real values, then restart `npm run dev`.

# Optional. URL of your deployed Nodemailer backend (see /server) that powers
# the "Get In Touch" form's Gmail delivery + auto-reply.
#
# If you leave this unset, the contact form automatically falls back to
# Formspree, so the site keeps working even before you deploy the backend.
#
# Example once deployed:
# VITE_CONTACT_API_URL=https://smartflow-contact.onrender.com/api/contact
VITE_CONTACT_API_URL=
